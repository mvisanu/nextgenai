# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit real values.

# PostgreSQL DSN for sync SQLAlchemy connections
PG_DSN=postgresql://user:password@localhost:5432/nextai?sslmode=require

# PostgreSQL DSN for async SQLAlchemy connections (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nextai?ssl=require

# Anthropic API key — must be sk-ant-api03-... format
ANTHROPIC_API_KEY=sk-ant-api03-...

# Wave 4 — Supabase Auth
# JWT secret used to verify Supabase-issued tokens server-side (HS256).
# Get this from: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
# IMPORTANT: This is a backend-only secret — never expose in NEXT_PUBLIC_ vars or frontend code.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
