# ============================================================
# NextAgentAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Database
# Local dev: postgresql://postgres:postgres@localhost:5432/nextai
# Neon (external): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/nextai?sslmode=require
# -----------------------------------------------------------
PG_DSN=postgresql://postgres:postgres@localhost:5432/nextai
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextai

# -----------------------------------------------------------
# Anthropic LLM
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------
# Kaggle (optional — fallback to demo/seed_sql/ CSVs if absent)
# Get credentials at: https://www.kaggle.com/settings/account
# -----------------------------------------------------------
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# -----------------------------------------------------------
# Local Docker Postgres (used only for docker-compose)
# -----------------------------------------------------------
POSTGRES_DB=nextai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
