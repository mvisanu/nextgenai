# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored — never commit real values.

# Backend URL — must match where the FastAPI server is running
NEXT_PUBLIC_API_URL=http://localhost:8000

# Wave 4 — Supabase Auth
# Get these from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Full frontend URL used as the base for email redirect links (sign-up confirmation, password reset).
# Dev: http://localhost:3005  |  Prod: https://nextgenai-seven.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3005
