      <data key="d0">23-year-old Female</data>
      <data key="d1">person</data>
      <data key="d2">A 23-year-old female patient who presented with jaundice of 1 weeks duration, weight loss of 8 kg, and dark urine.</data>
      <data key="d3">chunk-913dac86f1445586ee7313cee3abcef4</data>
